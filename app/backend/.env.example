# PostgreSQL — ajuste usuário/senha/host conforme seu ambiente
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rh_litoral?schema=public"

# JWT
JWT_SECRET="troque-este-segredo-em-producao"
JWT_EXPIRES_IN="8h"

# Criptografia de campos sensíveis (CPF) — chave de 32 bytes em hex (64 chars)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=""

# API
PORT=3333
CORS_ORIGIN="http://localhost:5173"
